+++ b/Plugins/CDIReader/Reader/vtkCDIReader.cxx
@@ -252,6 +252,8 @@ vtkCDIReader::vtkCDIReader()
 
   vtkDebugMacro("MAX_VARS:" << MAX_VARS);
   vtkDebugMacro("Created vtkCDIReader");
