--- a/ThirdParty/viskores/CMakeLists.txt
+++ b/ThirdParty/viskores/CMakeLists.txt
@@ -24,7 +24,7 @@ vtk_module_third_party(
     STANDARD_INCLUDE_DIRS
   EXTERNAL
