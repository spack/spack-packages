 torch/csrc/jit/runtime/logging.cpp                     | 1 +
 torch/csrc/lazy/core/multi_wait.cpp                    | 1 +
 3 files changed, 4 insertions(+), 1 deletion(-)

diff --git a/torch/csrc/jit/passes/quantization/quantization_type.h b/torch/csrc/jit/passes/quantization/quantization_type.h
index ea5ca10b15a56c69cb1e56e82de3124c17f89d1f..ac4afe90ed9ea577a760becf2a2d760a6bd74d60 100644
--- a/torch/csrc/jit/passes/quantization/quantization_type.h
+++ b/torch/csrc/jit/passes/quantization/quantization_type.h
@@ -1,4 +1,5 @@
 #pragma once
+#include <cstdint>
 #include <ostream>
 
 namespace torch {
@@ -6,7 +7,7 @@ namespace jit {
 
 // Quantization type (dynamic quantization, static quantization).
 // Should match the Python enum in quantize_jit.py
-enum QuantType : uint8_t { DYNAMIC = 0, STATIC };
+enum QuantType : std::uint8_t { DYNAMIC = 0, STATIC };
 
 std::ostream& operator<<(std::ostream& os, QuantType t);
 
